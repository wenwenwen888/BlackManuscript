---
import SourceBar from "./SourceBar.astro";

interface Props {
  source: string;
  source_country: string;
  source_url: string;
  published: string;
  topic: string;
  title_cn: string;
  summary_cn: string;
  quote_cn?: string;
  absurdity: number;
}
const { source, source_country, source_url, published, topic, title_cn, summary_cn, quote_cn, absurdity } = Astro.props;

// 荒诞指数可视化：1-10 转 5 颗星
const stars = "★".repeat(Math.ceil(absurdity / 2)) + "☆".repeat(5 - Math.ceil(absurdity / 2));
---
<article class="news-card">
  <SourceBar source={source} source_country={source_country} source_url={source_url} published={published} />

  <a class="title" href={source_url} target="_blank" rel="noopener noreferrer">{title_cn}</a>

  <p class="summary">{summary_cn}</p>

  {quote_cn && (
    <blockquote class="quote">
      <span class="quote-mark">"</span>{quote_cn}<span class="quote-mark">"</span>
    </blockquote>
  )}

  <div class="meta">
    <span class="topic-tag">{topic}</span>
    <span class="absurdity">
      荒诞指数 <span class="absurdity-meter">{stars}</span> {absurdity}/10
    </span>
  </div>
</article>

