---
import NewsCard from "./NewsCard.astro";

interface Article {
  source: string;
  source_country: string;
  source_url: string;
  published: string;
  topic: string;
  title_cn: string;
  summary_cn: string;
  quote_cn?: string;
  absurdity: number;
}

interface Props {
  side: "left" | "right";
  articles: Article[];
}
const { side, articles } = Astro.props;

const labels = {
  left: { title: "外媒嘲讽国内", badge: "Foreign press on China" },
  right: { title: "中媒嘲讽海外", badge: "Chinese press on the world" },
};
const label = labels[side];
---
<section class={`versus-column ${side}`}>
  <header class={`column-header ${side}`}>
    <span>{label.title}</span>
    <span class="badge">{label.badge}</span>
  </header>
  <div class="column-body">
    {articles.length === 0 ? (
      <div class="empty">今日无内容</div>
    ) : (
      articles.map((a) => <NewsCard {...a} />)
    )}
  </div>
</section>
